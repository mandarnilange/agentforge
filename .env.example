# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Core
AGENTFORGE_DEFAULT_MODEL=claude-sonnet-4-20250514
AGENTFORGE_MAX_TOKENS=64000
AGENTFORGE_OUTPUT_DIR=./output
AGENTFORGE_LOG_LEVEL=info

# Optional — Platform only (requires agentforge)
# AGENTFORGE_STATE_STORE=postgres
# AGENTFORGE_POSTGRES_URL=postgres://user:pass@localhost:5432/agentforge
# AGENTFORGE_NODE_SECRET=your-shared-secret
# AGENTFORGE_MAX_TOKENS_PER_PIPELINE=500000
# AGENTFORGE_MAX_COST_PER_PIPELINE=10.00
# AGENTFORGE_MAX_CONCURRENT_RUNS_PER_PROJECT=3
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
