# Production environment configuration
# Copy to .env.prod and fill in values

# Required: LLM API key
ANTHROPIC_API_KEY=

# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=agentforge_secret

# Dashboard port
PORT=3001

# Worker replicas
WORKER_REPLICAS=1

# Grafana admin password
GRAFANA_PASSWORD=admin

# Rate limits (optional)
# AGENTFORGE_MAX_TOKENS_PER_PIPELINE=1000000
# AGENTFORGE_MAX_COST_PER_PIPELINE=50.0
# AGENTFORGE_MAX_CONCURRENT_RUNS_PER_PROJECT=3
