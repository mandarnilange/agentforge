{
	"name": "agentforge-core",
	"version": "0.2.0",
	"description": "AgentForge core: Kubernetes-style control plane for AI agent workflows — declarative YAML agents, pipelines, gates, and state",
	"type": "module",
	"bin": {
		"agentforge-core": "./dist/cli/index.js"
	},
	"main": "./dist/agents/index.js",
	"types": "./dist/agents/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/agents/index.d.ts",
			"import": "./dist/agents/index.js"
		},
		"./domain/*": "./dist/domain/*",
		"./di/*": "./dist/di/*",
		"./state/*": "./dist/state/*",
		"./control-plane/*": "./dist/control-plane/*",
		"./observability/*": "./dist/observability/*",
		"./adapters/*": "./dist/adapters/*",
		"./definitions/*": "./dist/definitions/*",
		"./cli/*": "./dist/cli/*",
		"./engine/*": "./dist/engine/*",
		"./schemas/*": "./dist/schemas/*",
		"./utils/*": "./dist/utils/*",
		"./templates/*": "./dist/templates/*"
	},
	"scripts": {
		"build": "npm run --prefix ../.. build",
		"typecheck": "tsc --noEmit",
		"pack:dry-run": "npm pack --dry-run",
		"prepublishOnly": "npm run --prefix ../.. build"
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/mandarnilange/agentforge#readme",
	"bugs": {
		"url": "https://github.com/mandarnilange/agentforge/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mandarnilange/agentforge.git",
		"directory": "packages/core"
	},
	"keywords": [
		"ai",
		"agents",
		"agentforge",
		"pipeline",
		"automation",
		"anthropic",
		"claude",
		"orchestration",
		"code-generation"
	],
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.65.0",
		"@mariozechner/pi-ai": "^0.65.0",
		"@mariozechner/pi-coding-agent": "^0.65.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"ajv": "^8.18.0",
		"better-sqlite3": "^12.8.0",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"dotenv": "^17.4.0",
		"ora": "^9.3.0",
		"pdfkit": "^0.18.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	}
}
